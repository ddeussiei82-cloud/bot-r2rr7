def auto_update_json():
    while True:
        try:

            url = f"https://api.github.com/repos/{GITHUB_REPO}/contents/Bypass.json"
            headers = {
                "Authorization": f"token {GITHUB_TOKEN}",
                "Accept": "application/vnd.github.v3+json"
            }
            
            response = requests.get(url, headers=headers)
            
            if response.status_code == 200:
                data = response.json()
                sha = data['sha']

                content = json.loads(base64.b64decode(data['content']).decode())
                current_version = content.get("bypassVersion", 0)
                
         
                new_version = current_version + 1
                new_content = {"bypassVersion": new_version}
                

                payload = {
                    "message": f"Auto Update Version to {new_version}",
                    "content": base64.b64encode(json.dumps(new_content, indent=2).encode()).decode(),
                    "sha": sha,
                    "branch": GITHUB_BRANCH
                }
                
                put_res = requests.put(url, headers=headers, json=payload)
                if put_res.status_code in [200, 201]:
                    print(f"- [تحديث تلقائي] تم رفع الإصدار الجديد: {new_version} - .")
            
        except Exception as e:
            print(f"- [خطأ] فشل التحديث التلقائي: {e} - .")
            

        time.sleep(3600)


threading.Thread(target=auto_update_json, daemon=True).start()


print("Bot running - جاري تشغيل البوت...")

bot.infinity_polling()