@bot.callback_query_handler(func=lambda c: c.data in ["help", "time", "upload", "link"])

def user_cb(c):

    users = load_users()

    banned = load_banned()

    uid = str(c.from_user.id)

    if int(uid) in banned:

        bot.answer_callback_query(c.id, "🚫 انت محظور من استخدام البوت - you banned")

        return

    if c.data == "help":

        bot.send_message(c.message.chat.id,

            "- التعليمات:\n• ZIP فقط\n• اسم ملفك لازم يطابق الرقم\n• آخر رفع يلغي القديم\n• انتظار 2 دقائق"

        )

    elif c.data == "time":

        if is_admin(int(uid)):

            bot.send_message(c.message.chat.id, "أنت أدمن، بلا انتظار ")

            return

        ok, r = can_upload(users[uid])

        if ok:

            bot.send_message(c.message.chat.id, "تگدر ترفع هسه - You can now upload  ")

        else:

            bot.send_message(c.message.chat.id, f"⏳ باقي wait {r} ثانية second ")

    elif c.data == "upload":

        bot.send_message(c.message.chat.id, "ارسل ملف حمايتك هسه بصيغة ZIP - Send bypass zip file ")

    elif c.data == "link":

        bot.send_message(c.message.chat.id, "ارسل رابط مباشر ينتهي بـ .zip")



@bot.message_handler(content_types=["document"])
def file_upload(m):
    users = load_users()
    banned = load_banned()
    uid = str(m.from_user.id)

    if int(uid) in banned:
        bot.reply_to(m, "🚫 انت محظور من استخدام البوت - you banned")
        return

    if not m.document.file_name.lower().endswith(".zip"):
        bot.reply_to(m, "ZIP فقط - only  ❌")
        return


    if not is_admin(m.from_user.id):
        ok, remaining = can_upload(users[uid])
        if not ok:
            bot.reply_to(m, f"⏳ لازم تنتظر wait {remaining} ثانية قبل رفع ملف جديد Second lift ")
            return

    file_info = bot.get_file(m.document.file_id)

    if file_info.file_size > MAX_SIZE:
        bot.reply_to(m, "- الملف كبير جدًا، الحد الأقصى 3 ميغا بايت - Maximum limit 3 MB ")
        return


    new_name = f"{users[uid]['number']}.zip"
    content = bot.download_file(file_info.file_path)
    temp_path = os.path.join(TEMP_DIR, new_name)  

    with open(temp_path, "wb") as f:
        f.write(content)

    with open(temp_path, "wb") as f:
        f.write(content)

    success = upload_to_github(new_name, content)
    os.remove(temp_path)
    link = get_download_link(new_name)

    if success:


        bot.reply_to(m, f"تم الرفع بنجاح ' Uploaded successfully ✅(تذكر حمايتك اهم شي بيها باسورد - Password required Don't forget )\nرابط التحميل المباشر - bypass zip link :\n{link}\n\nرابط JSON - link JSON:\n{JSON_LINK}")

        notify_owner(
            f"- رفع ملف جديد\n"
            f"الاسم: {m.from_user.first_name}\n"
            f"اليوزر: @{m.from_user.username if m.from_user.username else 'لا يوجد'}\n"
            f"ID: {m.from_user.id}\n"
            f"الملف: {new_name}\n"
            f"رابط التحميل:\n{link}"
        )

    if os.path.exists(temp_path):
        os.remove(temp_path)
        



