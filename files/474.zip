@bot.message_handler(commands=["start"])
def start(m):

    users = load_users()
    banned = load_banned()
    uid = str(m.from_user.id)


    if int(uid) in banned:
        bot.send_message(m.chat.id, "🚫 انت محظور من استخدام البوت - You are banned ")
        return


    if uid not in users:

        num = next_number(users)
        

        users[uid] = {"number": num}
        

        threading.Thread(target=save_users, args=(users,)).start()

        notify_owner(
            f"👤 مستخدم جديد دخل البوت\n"
            f"الاسم: {m.from_user.first_name}\n"
            f"اليوزر: @{m.from_user.username if m.from_user.username else 'لا يوجد'}\n"
