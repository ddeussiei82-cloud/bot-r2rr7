@bot.callback_query_handler(func=lambda c: str(c.data).startswith("admin_"))

def admin_cb(c):

    uid = c.from_user.id

    if not is_admin(uid):

        return

    users = load_users()

    banned = load_banned()

    if c.data == "admin_ban":

        bot.send_message(c.message.chat.id, "- ارسل ID المستخدم للحظر")

        bot.register_next_step_handler(c.message, ban_user)

    elif c.data == "admin_unban":

        bot.send_message(c.message.chat.id, "- ارسل ID المستخدم لرفع الحظر")

        bot.register_next_step_handler(c.message, unban_user)
    elif c.data == "admin_broadcast":
        bot.send_message(c.message.chat.id, "- ارسل نص الإذاعة الآن (نص فقط)")
        bot.register_next_step_handler(c.message, send_broadcast)
    
    elif c.data == "admin_stats":

        total_users = len(users)

        total_banned = len(banned)

        bot.send_message(c.message.chat.id, f"- إحصائيات البوت:\n• إجمالي المستخدمين: {total_users}\n• محظورين: {total_banned}")



def ban_user(m):

    text = m.text.strip() 

    if not text.isdigit(): 

        bot.reply_to(m, "ؤ- خطأ: ID لازم يكون رقم صحيح")

        return

    uid = int(text)

    banned = load_banned()

    if uid in banned:

        bot.reply_to(m, f"المستخدم {uid} محظور بالفعل")

    else:

        banned.append(uid)

        save_banned(banned)

        bot.reply_to(m, f"- تم حظر المستخدم {uid}")
        
def send_broadcast(m):
    users = load_users()
    text = m.text  
    success = 0
    failed = 0

    for uid in users.keys():
        try:
            bot.send_message(uid, text)
            success += 1
        except:
            failed += 1

    m.reply(f"- تم الإرسال:\nنجاح: {success}\nفشل: {failed}")

def unban_user(m):

    text = m.text.strip() 

    if not text.isdigit():

        bot.reply_to(m, "- خطأ: ID لازم يكون رقم صحيح")

        return

    uid = int(text)

    banned = load_banned()

    if uid in banned:

        banned.remove(uid)

        save_banned(banned)

        bot.reply_to(m, f"- تم رفع الحظر عن المستخدم {uid}")

    else:

        bot.reply_to(m, f"المستخدم {uid} ليس محظورًا")

        

