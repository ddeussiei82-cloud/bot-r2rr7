def load_users():
    url = f"https://raw.githubusercontent.com/{GITHUB_REPO}/{GITHUB_BRANCH}/{USERS_FILE}"
    try:
        r = requests.get(url)
        if r.status_code == 200:
            return r.json()
        else:
            return {}
    except:
        return {}

def save_users(data):
    path = USERS_FILE
    url = f"https://api.github.com/repos/{GITHUB_REPO}/contents/{path}"
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github.v3+json"
    }
    r = requests.get(url, headers=headers)
    sha = r.json().get("sha") if r.status_code == 200 else None

    payload = {
        "message": f"Update {USERS_FILE}",
        "content": base64.b64encode(json.dumps(data, indent=2).encode()).decode(),
        "branch": GITHUB_BRANCH
    }
    if sha:
        payload["sha"] = sha

    requests.put(url, headers=headers, json=payload)

def load_banned():
    url = f"https://raw.githubusercontent.com/{GITHUB_REPO}/{GITHUB_BRANCH}/{BANNED_FILE}"
    try:
        r = requests.get(url)
        if r.status_code == 200:
            data = r.json()
            return data if isinstance(data, list) else []
        else:
            return []
    except:
        return []

def save_banned(data):
    path = BANNED_FILE
    url = f"https://api.github.com/repos/{GITHUB_REPO}/contents/{path}"
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github.v3+json"
    }
    r = requests.get(url, headers=headers)
    sha = r.json().get("sha") if r.status_code == 200 else None

    payload = {
        "message": f"Update {BANNED_FILE}",
        "content": base64.b64encode(json.dumps(data, indent=2).encode()).decode(),
        "branch": GITHUB_BRANCH
    }
    if sha:
        payload["sha"] = sha

    requests.put(url, headers=headers, json=payload)

def is_admin(uid):

    return uid == OWNER_ID

def next_number(users):

    nums = [v["number"] for v in users.values()]

    return max(nums)+1 if nums else 1

def can_upload(user):

    last = user.get("last_upload", 0)

    diff = int(time.time() - last)

    if diff >= WAIT_TIME:

        return True, 0

    return False, WAIT_TIME - diff

def upload_to_github(filename, content):

    path = f"{GITHUB_PATH}/{filename}"

    url = f"https://api.github.com/repos/{GITHUB_REPO}/contents/{path}"

    headers = {"Authorization": f"token {GITHUB_TOKEN}",

               "Accept": "application/vnd.github.v3+json"}

    r = requests.get(url, headers=headers)

    sha = r.json().get("sha") if r.status_code == 200 else None

    data = {

        "message": f"upload {filename}",

        "content": base64.b64encode(content).decode(),

        "branch": GITHUB_BRANCH

    }

    if sha:

        data["sha"] = sha

    res = requests.put(url, headers=headers, json=data)

    return res.status_code in (200, 201)

def get_download_link(filename):

    return f"https://raw.githubusercontent.com/{GITHUB_REPO}/{GITHUB_BRANCH}/{GITHUB_PATH}/{filename}"

